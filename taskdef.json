{
  "family": "photo-uploader-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::904233109505:role/photo-uploader-task-execution-role",
  "taskRoleArn": "arn:aws:iam::904233109505:role/photo-uploader-task-role",
  "containerDefinitions": [
    {
      "name": "photo-uploader",
      "image": "<IMAGE1_NAME>",
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "DB_HOST",
          "value": "photo-uploader-db.c14awss8ucz8.eu-central-1.rds.amazonaws.com"
        },
        {
          "name": "DB_NAME",
          "value": "photouploader"
        },
        {
          "name": "DB_USERNAME",
          "value": "adminuser"
        },
        {
          "name": "S3_BUCKET_NAME",
          "value": "photo-uploader-photos-904233109505"
        },
        {
          "name": "CLOUDFRONT_DOMAIN",
          "value": "d1e9ibx9qv0zc0.cloudfront.net"
        },
        {
          "name": "AWS_REGION",
          "value": "eu-central-1"
        }
      ],
      "secrets": [
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:904233109505:secret:/photo-uploader/db/password"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/photo-uploader",
          "awslogs-region": "eu-central-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}