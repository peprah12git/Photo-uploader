{
  "family": "photo-uploader-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::825765391206:role/photo-uploader-task-execution-role",
  "taskRoleArn": "arn:aws:iam::825765391206:role/photo-uploader-task-role",
  "containerDefinitions": [
    {
      "name": "photo-uploader",
      "image": "<IMAGE1_NAME>",
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "DB_HOST",
          "value": "<DB_HOST>"
        },
        {
          "name": "DB_NAME",
          "value": "photouploader"
        },
        {
          "name": "DB_USERNAME",
          "value": "adminuser"
        },
        {
          "name": "S3_BUCKET_NAME",
          "value": "<S3_BUCKET_NAME>"
        },
        {
          "name": "CLOUDFRONT_DOMAIN",
          "value": "<CLOUDFRONT_DOMAIN>"
        },
        {
          "name": "AWS_REGION",
          "value": "eu-central-1"
        }
      ],
      "secrets": [
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:825765391206:secret:/photo-uploader/db/password:password::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/photo-uploader",
          "awslogs-region": "eu-central-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}